# OpenWrt 25.12 — Ruijie RG-MA3063
# Target  : qualcommax/ipq50xx, arm64, kernel 6.12
# Flash   : 50MB rootfs (mtd15) — keep image lean
# IPv6    : DISABLED
# PKG MGR : apk (bukan opkg, berubah di 25.12)

# ── Target ────────────────────────────────────────────────────
CONFIG_TARGET_qualcommax=y
CONFIG_TARGET_qualcommax_ipq50xx=y
CONFIG_TARGET_qualcommax_ipq50xx_DEVICE_ruijie_rg-ma3063=y

# ── WiFi — ath11k ─────────────────────────────────────────────
CONFIG_PACKAGE_kmod-ath11k=y
CONFIG_PACKAGE_kmod-ath11k-ahb=y
CONFIG_PACKAGE_kmod-ath11k-pci=y
CONFIG_PACKAGE_ath11k-firmware-ipq5018=y
CONFIG_PACKAGE_hostapd=y
CONFIG_PACKAGE_iwinfo=y
CONFIG_PACKAGE_iw=y

# ── LuCI minimal ──────────────────────────────────────────────
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-mod-admin-full=y
CONFIG_PACKAGE_luci-mod-network=y
CONFIG_PACKAGE_luci-mod-status=y
CONFIG_PACKAGE_luci-mod-system=y
CONFIG_PACKAGE_luci-app-firewall=y
CONFIG_PACKAGE_luci-app-wireless=y
CONFIG_PACKAGE_luci-theme-bootstrap=y
CONFIG_PACKAGE_luci-app-apk=y

# ── mwan3 + LuCI ──────────────────────────────────────────────
CONFIG_PACKAGE_mwan3=y
CONFIG_PACKAGE_luci-app-mwan3=y

# ── Networking ────────────────────────────────────────────────
CONFIG_PACKAGE_firewall4=y
CONFIG_PACKAGE_nftables=y
CONFIG_PACKAGE_kmod-nft-offload=y

# dnsmasq-full: sama ukurannya tapi ada DNSSEC + filtering
CONFIG_PACKAGE_dnsmasq=n
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_wpad-basic=n
CONFIG_PACKAGE_wpad=y

CONFIG_PACKAGE_ppp=y
CONFIG_PACKAGE_ppp-mod-pppoe=y

# ── IPv6 — DISABLED ───────────────────────────────────────────
CONFIG_PACKAGE_odhcp6c=n
CONFIG_PACKAGE_odhcpd-ipv6only=n
CONFIG_PACKAGE_kmod-ipv6=n
CONFIG_IPV6=n

# ── Utilities minimal ─────────────────────────────────────────
# uclient-fetch lebih ringan dari curl (~500KB hemat)
CONFIG_PACKAGE_uclient-fetch=y
CONFIG_PACKAGE_curl=n
CONFIG_PACKAGE_nano=y

# SFTP untuk SCP transfer file — opsional tapi useful
CONFIG_PACKAGE_openssh-sftp-server=y

# ── NAND / UBI ────────────────────────────────────────────────
CONFIG_PACKAGE_kmod-mtd-rw=y
CONFIG_PACKAGE_uboot-envtools=y
CONFIG_PACKAGE_mtd=y

# ── Tidak dipakai — eksplisit disable ─────────────────────────
CONFIG_PACKAGE_htop=n
CONFIG_PACKAGE_bash=n
CONFIG_PACKAGE_wget-ssl=y
CONFIG_PACKAGE_wireless-tools=n
CONFIG_PACKAGE_hostapd-utils=n
CONFIG_PACKAGE_luci-app-opkg=n

# ── Image format ──────────────────────────────────────────────
CONFIG_TARGET_ROOTFS_SQUASHFS=y
CONFIG_TARGET_ROOTFS_INITRAMFS=y
CONFIG_TARGET_INITRAMFS_COMPRESSION_LZMA=y
