/*
 * Device Tree Source for Ruijie RG-MA3063
 *
 * Hardware Specifications:
 *   SoC  : Qualcomm IPQ5000 (IPQ50xx family, compatible with IPQ5018)
 *   CPU  : Dual-core ARM Cortex-A53 @ 1.0 GHz
 *   RAM  : 256 MB DDR (@ 0x40000000)
 *   Flash: 128 MB SPI NAND
 *   WiFi : AX3000 (2.4 GHz IPQ5018 internal + 5 GHz QCN6122 external)
 *   ETH  : 4x Gigabit RJ45 (1x WAN + 3x LAN), QCA8337 switch
 *   Power: DC 12V
 *
 * Verification Status (all confirmed from live hardware):
 *   ✅ Partition layout  : /proc/mtd (20 partitions)
 *   ✅ GPIO 26 (sw rst)  : dmesg "GPIO26 reset switch done"
 *   ✅ GPIO 37 (reset)   : polling test (active-low, normally HIGH)
 *   ✅ LED controller    : SSDK via QCA8337 (ssdk_led_mode:3, led_map:0xffc)
 *   ✅ MAC address       : 48:81:d4:8a:dc:e5 (ART offset 0x0)
 *   ✅ IPQ5018 caldata   : ART offset 0x1000, 128KB
 *   ✅ QCN6122 caldata   : ART offset 0x26800, 128KB
 *   ✅ IPQ5018 BDF       : bdwlan.b23 (board_id 23, cnss[2])
 *   ✅ QCN6122 BDF       : qcn6122/bdwlan.b60 (board_id 60, cnss[41])
 *   ✅ WAN port          : eth0 → dp1 (IPQ5018 internal GE PHY)
 *   ✅ LAN ports         : eth1-3 → dp2-4 (QCA8337 port 1-3)
 *
 * Copyright (C) 2025 OpenWrt Contributors
 */

#include "ipq5018.dtsi"
#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/input/input.h>
#include <dt-bindings/leds/common.h>

/ {
	model = "Ruijie RG-MA3063";
	compatible = "ruijie,rg-ma3063", "qcom,ipq5018";

	/* ============================================================
	 * MEMORY — 256MB DDR
	 * ============================================================ */
	memory@40000000 {
		device_type = "memory";
		reg = <0x0 0x40000000 0x0 0x10000000>;
	};

	/* ============================================================
	 * ALIASES
	 * ============================================================ */
	aliases {
		serial0   = &blsp1_uart1;
		serial1   = &blsp1_uart2;
		ethernet0 = &dp1;
		ethernet1 = &dp2;
		ethernet2 = &dp3;
		ethernet3 = &dp4;
		label-mac-device = &dp1;
	};

	/* ============================================================
	 * CHOSEN
	 * ============================================================ */
	chosen {
		stdout-path = "serial0:115200n8";
		bootargs-append = " ubi.mtd=rootfs root=mtd:ubi_rootfs rootfstype=squashfs rootwait";
	};

	/* ============================================================
	 * GPIO KEYS — Reset Button
	 *
	 * ✅ GPIO 37 = reset button (verified: polling test)
	 *    Normally HIGH (pull-up), goes LOW when pressed → ACTIVE_LOW
	 * ============================================================ */
	keys {
		compatible = "gpio-keys";

		reset {
			label = "reset";
			linux,code = <KEY_RESTART>;
			gpios = <&tlmm 37 GPIO_ACTIVE_LOW>;	/* ✅ VERIFIED */
			debounce-interval = <60>;
		};
	};

	/* ============================================================
	 * LEDS
	 *
	 * ✅ LED dikontrol oleh SSDK via QCA8337, bukan gpio-leds.
	 *    dmesg: "ssdk_led_mode:3, ssdk_led_map:ffc, ssdk_led_src_id:0"
	 *    6 LED fisik: led1_{blue,green,red} + led2_{blue,green,red}
	 *
	 * Konfigurasi LED ada di node switch0 (QCA8337) di bawah.
	 * Untuk trigger OpenWrt, gunakan LuCI → System → LED Configuration
	 * atau /etc/board.d/01_leds.
	 * ============================================================ */
};

/* ==============================================================
 * UART — Serial Console (115200 8N1)
 * ============================================================== */
&blsp1_uart1 {
	status = "okay";
};

/* ==============================================================
 * QPIC NAND FLASH — 128MB SPI NAND
 *
 * ✅ Layout partisi DIVERIFIKASI dari /proc/mtd perangkat asli.
 *
 * +----+-----------------+------------+----------+-------------------------+
 * | mtd| Label           | Offset     | Size     | Description             |
 * +----+-----------------+------------+----------+-------------------------+
 * |  0 | 0:SBL1          | 0x0000000  | 512KB    | Secondary Bootloader    |
 * |  1 | 0:MIBIB         | 0x0080000  | 512KB    | SMEM Partition Table    |
 * |  2 | 0:BOOTCONFIG    | 0x0100000  | 256KB    | Boot Config A           |
 * |  3 | 0:BOOTCONFIG1   | 0x0140000  | 256KB    | Boot Config B           |
 * |  4 | 0:QSEE          | 0x0180000  | 1MB      | TrustZone A             |
 * |  5 | 0:QSEE_1        | 0x0280000  | 1MB      | TrustZone B             |
 * |  6 | 0:DEVCFG        | 0x0380000  | 256KB    | Device Config A         |
 * |  7 | 0:DEVCFG_1      | 0x03c0000  | 256KB    | Device Config B         |
 * |  8 | 0:CDT           | 0x0400000  | 256KB    | Clock & DDR Config A    |
 * |  9 | 0:CDT_1         | 0x0440000  | 256KB    | Clock & DDR Config B    |
 * | 10 | 0:APPSBLENV     | 0x0480000  | 512KB    | U-Boot Environment      |
 * | 11 | 0:APPSBL        | 0x0500000  | 1.25MB   | U-Boot A                |
 * | 12 | 0:APPSBL_1      | 0x0640000  | 1.25MB   | U-Boot B                |
 * | 13 | 0:ART           | 0x0780000  | 1MB      | WiFi Cal + MAC ⚠        |
 * | 14 | 0:TRAINING      | 0x0880000  | 512KB    | NAND Serial Training    |
 * | 15 | rootfs          | 0x0900000  | 50MB     | ← TARGET OpenWrt        |
 * | 16 | rootfs_1        | 0x3b00000  | 50MB     | Backup / A-B update     |
 * | 17 | ttyMTD          | 0x6d00000  | 1.1MB    | Ruijie misc storage     |
 * | 18 | productinfo     | 0x6e20000  | 512KB    | Ruijie product info     |
 * | 19 | data            | 0x6ea0000  | 16.25MB  | Persistent data         |
 * +----+-----------------+------------+----------+-------------------------+
 * ============================================================== */
&qpic_nand {
	status = "okay";

	nand@0 {
		reg = <0>;
		nand-ecc-strength = <4>;
		nand-ecc-step-size = <512>;
		nand-bus-width = <8>;

		partitions {
			compatible = "fixed-partitions";
			#address-cells = <1>;
			#size-cells = <1>;

			partition@0 {
				label = "0:SBL1";
				reg = <0x0 0x80000>;
				read-only;
			};

			partition@80000 {
				label = "0:MIBIB";
				reg = <0x80000 0x80000>;
				read-only;
			};

			partition@100000 {
				label = "0:BOOTCONFIG";
				reg = <0x100000 0x40000>;
				read-only;
			};

			partition@140000 {
				label = "0:BOOTCONFIG1";
				reg = <0x140000 0x40000>;
				read-only;
			};

			partition@180000 {
				label = "0:QSEE";
				reg = <0x180000 0x100000>;
				read-only;
			};

			partition@280000 {
				label = "0:QSEE_1";
				reg = <0x280000 0x100000>;
				read-only;
			};

			partition@380000 {
				label = "0:DEVCFG";
				reg = <0x380000 0x40000>;
				read-only;
			};

			partition@3c0000 {
				label = "0:DEVCFG_1";
				reg = <0x3c0000 0x40000>;
				read-only;
			};

			partition@400000 {
				label = "0:CDT";
				reg = <0x400000 0x40000>;
				read-only;
			};

			partition@440000 {
				label = "0:CDT_1";
				reg = <0x440000 0x40000>;
				read-only;
			};

			partition@480000 {
				label = "0:APPSBLENV";
				reg = <0x480000 0x80000>;
			};

			partition@500000 {
				label = "0:APPSBL";
				reg = <0x500000 0x140000>;
				read-only;
			};

			partition@640000 {
				label = "0:APPSBL_1";
				reg = <0x640000 0x140000>;
				read-only;
			};

			/*
			 * ⚠ ART — WiFi Calibration Data + MAC Addresses
			 *   JANGAN PERNAH ditulis ulang / di-erase!
			 *   Backup wajib sebelum flashing:
			 *     dd if=/dev/mtd13 of=/tmp/art.bin.bak
			 *
			 * ART layout (verified from live hardware):
			 *   0x0000  : MAC ETH/WAN   → 48:81:d4:8a:dc:e5  ✅
			 *   0x0006  : MAC WiFi 2.4G → sama dengan ETH     ✅
			 *   0x000c  : MAC WiFi 5G   → FF (kosong di OEM)
			 *   0x1000  : IPQ5018 caldata (128KB = 0x20000)   ✅
			 *   0x26800 : QCN6122 caldata (128KB = 0x20000)   ✅
			 */
			partition@780000 {
				label = "0:ART";
				reg = <0x780000 0x100000>;
				read-only;

				nvmem-layout {
					compatible = "fixed-layout";
					#address-cells = <1>;
					#size-cells = <1>;

					/* ✅ MAC ETH/WAN — offset 0x0 */
					macaddr_art_eth: macaddr@0 {
						reg = <0x0 0x6>;
					};

					/* ✅ MAC WiFi 2.4GHz — offset 0x6 */
					macaddr_art_2g: macaddr@6 {
						reg = <0x6 0x6>;
					};

					/* ✅ IPQ5018 caldata — offset 0x1000, 128KB */
					caldata_2g: caldata@1000 {
						reg = <0x1000 0x20000>;
					};

					/* ✅ QCN6122 caldata — offset 0x26800, 128KB */
					caldata_5g: caldata@26800 {
						reg = <0x26800 0x20000>;
					};
				};
			};

			partition@880000 {
				label = "0:TRAINING";
				reg = <0x880000 0x80000>;
				read-only;
			};

			/* ← TARGET: OpenWrt dipasang di sini (UBI) */
			partition@900000 {
				label = "rootfs";
				reg = <0x900000 0x3200000>;
			};

			partition@3b00000 {
				label = "rootfs_1";
				reg = <0x3b00000 0x3200000>;
			};

			partition@6d00000 {
				label = "ttyMTD";
				reg = <0x6d00000 0x120000>;
			};

			partition@6e20000 {
				label = "productinfo";
				reg = <0x6e20000 0x80000>;
				read-only;
			};

			partition@6ea0000 {
				label = "data";
				reg = <0x6ea0000 0x1040000>;
			};
		};
	};
};

/* ==============================================================
 * MDIO0 — QCA8337 4-port Gigabit Switch
 *
 * ✅ GPIO 26 = switch reset (verified: dmesg "GPIO26 reset switch done")
 * ✅ LED dikontrol SSDK: ssdk_led_mode=3, ssdk_led_map=0xffc
 *    led_map 0xffc = bit[2..11] aktif = port 1-4 semua LED aktif
 *    mode 3 = menyala saat ada traffic (activity mode)
 *
 * Topologi:
 *   IPQ5018 GE PHY ──────── dp1 (WAN, eth0)
 *   QCA8337 port 1 ──────── LAN 1 (eth1)
 *   QCA8337 port 2 ──────── LAN 2 (eth2)
 *   QCA8337 port 3 ──────── LAN 3 (eth3)
 *   QCA8337 CPU port ─────── dp2 (ke IPQ5018)
 * ============================================================== */
&mdio0 {
	status = "okay";

	switch0: ethernet-switch@10 {
		compatible = "qca,qca8337";
		reg = <0x10>;

		/* ✅ GPIO 26 verified dari dmesg */
		reset-gpios = <&tlmm 26 GPIO_ACTIVE_LOW>;

		ports {
			#address-cells = <1>;
			#size-cells = <0>;

			/* CPU port — terhubung ke dp2 IPQ5018 */
			port@0 {
				reg = <0>;
				label = "cpu";
				ethernet = <&dp2>;
				phy-mode = "sgmii";
				fixed-link {
					speed = <1000>;
					full-duplex;
				};
			};

			/* ✅ LAN 1 (eth1) */
			port@1 {
				reg = <1>;
				label = "lan1";
				phy-handle = <&qca8337_phy0>;
			};

			/* ✅ LAN 2 (eth2) */
			port@2 {
				reg = <2>;
				label = "lan2";
				phy-handle = <&qca8337_phy1>;
			};

			/* ✅ LAN 3 (eth3) */
			port@3 {
				reg = <3>;
				label = "lan3";
				phy-handle = <&qca8337_phy2>;
			};
		};

		/*
		 * SSDK LED Configuration
		 * ✅ Confirmed: ssdk_led_mode=3, ssdk_led_map=0xffc, ssdk_led_src_id=0
		 * 6 LED fisik: led1_{blue,green,red} + led2_{blue,green,red}
		 */
		leds {
			#address-cells = <1>;
			#size-cells = <0>;

			led@0 {
				reg = <0>;
				color = <LED_COLOR_ID_GREEN>;
				function = LED_FUNCTION_LAN;
				default-state = "keep";
			};

			led@1 {
				reg = <1>;
				color = <LED_COLOR_ID_BLUE>;
				function = LED_FUNCTION_WAN;
				default-state = "keep";
			};

			led@2 {
				reg = <2>;
				color = <LED_COLOR_ID_RED>;
				function = LED_FUNCTION_FAULT;
				panic-indicator;
				default-state = "off";
			};
		};
	};
};

/* QCA8337 PHY nodes di mdio1 */
&mdio1 {
	status = "okay";

	qca8337_phy0: phy@0 { reg = <0>; };
	qca8337_phy1: phy@1 { reg = <1>; };
	qca8337_phy2: phy@2 { reg = <2>; };
};

/* ==============================================================
 * DATA PATH — Ethernet ports
 *
 * ✅ Verified dari OEM firmware:
 *   eth0 = WAN → dp1 (IPQ5018 internal GE PHY)
 *   eth1 = LAN1 → dp2 (QCA8337 via switch0 CPU port)
 *   eth2 = LAN2 → dp3
 *   eth3 = LAN3 → dp4
 * ============================================================== */

/* WAN — IPQ5018 internal GE PHY, langsung tanpa switch */
&dp1 {
	status = "okay";
	phy-mode = "sgmii";
	label = "wan";
	nvmem-cells = <&macaddr_art_eth>;
	nvmem-cell-names = "mac-address";
};

/* LAN1 — via QCA8337 CPU port */
&dp2 {
	status = "okay";
	phy-mode = "sgmii";
	label = "lan1";
	nvmem-cells = <&macaddr_art_eth>;
	nvmem-cell-names = "mac-address";
	mac-address-increment = <1>;
};

&dp3 {
	status = "okay";
	phy-mode = "sgmii";
	label = "lan2";
	nvmem-cells = <&macaddr_art_eth>;
	nvmem-cell-names = "mac-address";
	mac-address-increment = <2>;
};

&dp4 {
	status = "okay";
	phy-mode = "sgmii";
	label = "lan3";
	nvmem-cells = <&macaddr_art_eth>;
	nvmem-cell-names = "mac-address";
	mac-address-increment = <3>;
};

/* ==============================================================
 * ESS SWITCH — Internal switch config IPQ50xx
 *
 * ✅ WAN = dp1 langsung ke IPQ5018 GE PHY (tidak lewat QCA8337)
 *    switch_wan_bmp = 0x00 (tidak ada port WAN di switch)
 *    switch_lan_bmp = 0x1e (port 1,2,3,4 semua LAN side)
 * ============================================================== */
&ess_switch {
	status = "okay";
	switch_lan_bmp = <0x1e>;	/* port 1-4 = LAN */
	switch_wan_bmp = <0x00>;	/* WAN via dp1 langsung, bukan switch */
	switch_mac_mode = <0x00>;	/* PSGMII */
	switch_mac_mode1 = <0xff>;
	switch_mac_mode2 = <0xff>;

	qcom,port_phyinfo {
		port@1 {
			port_id = <1>;
			phy_address = <0>;
		};
		port@2 {
			port_id = <2>;
			phy_address = <1>;
		};
		port@3 {
			port_id = <3>;
			phy_address = <2>;
		};
	};
};

/* ==============================================================
 * WiFi 2.4GHz — IPQ5018 Internal Radio (ath11k)
 *
 * ✅ BDF aktif: bdwlan.b23 (board_id 23, confirmed dmesg cnss[2])
 * ✅ caldata: ART offset 0x1000, 128KB
 * ✅ MAC: ART offset 0x6
 *
 * Firmware path (ath11k):
 *   /lib/firmware/ath11k/IPQ5018/hw1.0/board.bin ← bdwlan.b23
 * ============================================================== */
&wifi0 {
	status = "okay";
	nvmem-cells = <&macaddr_art_2g>, <&caldata_2g>;
	nvmem-cell-names = "mac-address", "calibration";
};

/* ==============================================================
 * WiFi 5GHz — QCN6122 External Radio (ath11k MPD)
 *
 * ✅ BDF aktif: qcn6122/bdwlan.b60 (board_id 60, confirmed dmesg cnss[41])
 * ✅ caldata: ART offset 0x26800, 128KB (confirmed python3 search)
 * ✅ MAC: ETH MAC + 2 (offset 0xc di ART = FF di OEM)
 *
 * Firmware path (ath11k):
 *   /lib/firmware/ath11k/QCN6122/hw1.0/board.bin  ← bdwlan.b60
 *   /lib/firmware/ath11k/QCN6122/hw1.0/q6_fw.*
 *   /lib/firmware/ath11k/QCN6122/hw1.0/m3_fw.*
 * ============================================================== */
&wifi1 {
	status = "okay";
	nvmem-cells = <&macaddr_art_eth>, <&caldata_5g>;
	nvmem-cell-names = "mac-address", "calibration";
	mac-address-increment = <2>;
};

/* ==============================================================
 * USB — Tidak tersedia di RG-MA3063
 * ============================================================== */
&usb {
	status = "disabled";
};

/* ==============================================================
 * THERMAL — Manajemen suhu SoC
 * ============================================================== */
&tsens {
	status = "okay";
};
